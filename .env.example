# Neon Postgres. DATABASE_URL is the pooled URL (-pooler...); DIRECT is the
# direct one used by Prisma migrations and the shadow DB.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth (panel login). Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="<32-byte base64>"
AUTH_URL="https://portal.mahadahlan.com"

# Created on first `npm run db:seed`.
ADMIN_EMAIL="admin@mahadahlan.com"
ADMIN_PASSWORD="change-me-please"
ADMIN_NAME="Mahadahlan Admin"

# Optional — restricts /api/leads CORS to listed origins (comma-separated).
# Leave empty to allow any origin.
LANDING_ORIGINS="https://mahadahlan.com"

# Optional — used in canonical/OG metadata on the landings.
NEXT_PUBLIC_SITE_URL="https://mahadahlan.com"

# Optional — used by the gpt-image-2 skill (local dev only).
# OPENAI_API_KEY="sk-proj-..."
