# Dashboard URL where leads get forwarded. In dev, point this at the local
# dashboard (mahadahlanpanel) on port 3001 — see its package scripts.
LEAD_PANEL_URL="https://panel.mahadahlan.com"

# Per-landing API keys. The dashboard issues these via `prisma db seed` and
# rotates them from /dashboard/sources. The naming convention is:
#   slug "dark-circles"  →  LEAD_API_KEY_DARK_CIRCLES
#   slug "hyperpigmentation"  →  LEAD_API_KEY_HYPERPIGMENTATION
LEAD_API_KEY_BOTOX="mdp_botox_<rotate me>"
LEAD_API_KEY_HYPERPIGMENTATION="mdp_hyperpigmentation_<rotate me>"
LEAD_API_KEY_HAIR="mdp_hair_<rotate me>"
LEAD_API_KEY_DARK_CIRCLES="mdp_dark-circles_<rotate me>"
# Optional — only needed if these landings start collecting form leads
# instead of relying on WhatsApp CTAs:
# LEAD_API_KEY_ACNE="mdp_acne_<rotate me>"
# LEAD_API_KEY_FACIAL="mdp_facial_<rotate me>"
# LEAD_API_KEY_STRETCHMARKS="mdp_stretchmarks_<rotate me>"

# Optional — used for canonical links, OG tags, etc.
NEXT_PUBLIC_SITE_URL="https://mahadahlan.com"

# Optional — used by the gpt-image-2 skill (image generation).
# OPENAI_API_KEY="sk-proj-..."
