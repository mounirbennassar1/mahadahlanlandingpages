# Existing dashboard's lead ingest API. Every landing posts to /api/leads in
# this app, which forwards to ${LEAD_PANEL_URL}/api/leads with the API key.
LEAD_PANEL_URL="https://dashboard.mahadahlan.com"
LEAD_API_KEY="<dashboard api key>"

# Optional — only needed if a future landing needs to read directly from the
# dashboard's Postgres (e.g. to render data on the page). Lead writes go
# through LEAD_PANEL_URL above and do NOT use this.
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Optional — used for canonical links, OG tags, etc.
NEXT_PUBLIC_SITE_URL="https://mahadahlan.com"

# Optional — used by the gpt-image-2 skill (image generation).
# OPENAI_API_KEY="sk-proj-..."
